---
import TeaLinuxLogo from "../ui/TeaLinuxLogo.astro";
---

<div class="flex max-w-sm flex-col items-start">
  <div class="text-primary mb-8 h-16 w-16">
    <TeaLinuxLogo />
  </div>

  <h3 class="font-display text-on-surface mb-6 text-2xl font-bold tracking-widest uppercase">
    RELEASE PARTY 26
  </h3>

  <p class="font-label text-on-surface-variant text-xs leading-loose tracking-[0.2em] uppercase">
    Powered by Doscom.<br />
    TeaLinux OS is an open source<br />
    project<br />
    For developers by developers.
  </p>
</div>

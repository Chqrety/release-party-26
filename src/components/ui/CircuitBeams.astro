---

<svg class="absolute inset-0 w-full h-full z-0 opacity-70 pointer-events-none" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="beam-horizontal" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" stop-color="transparent"></stop>
      <stop offset="30%" stop-color="var(--color-primary)" stop-opacity="0.8"></stop>
      <stop offset="50%" stop-color="var(--color-primary)"></stop>
      <stop offset="70%" stop-color="var(--color-primary)" stop-opacity="0.8"></stop>
      <stop offset="100%" stop-color="transparent"></stop>
    </linearGradient>
    <linearGradient id="beam-vertical" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" stop-color="transparent"></stop>
      <stop offset="30%" stop-color="var(--color-primary)" stop-opacity="0.8"></stop>
      <stop offset="50%" stop-color="var(--color-primary)"></stop>
      <stop offset="70%" stop-color="var(--color-primary)" stop-opacity="0.8"></stop>
      <stop offset="100%" stop-color="transparent"></stop>
    </linearGradient>
  </defs>

  <g class="opacity-50">
    <line x1="0" y1="30%" x2="100%" y2="30%" stroke="var(--color-surface-highest)" stroke-width="3"></line>
    <rect y="calc(30% - 6px)" width="450" height="4" fill="url(#beam-horizontal)" class="drop-shadow-glow">
      <animate attributeName="x" from="-450" to="150vw" dur="4s" repeatCount="indefinite"></animate>
    </rect>
  </g>

  <g class="opacity-40">
    <line x1="25%" y1="0" x2="25%" y2="100%" stroke="var(--color-surface-highest)" stroke-width="3"></line>
    <rect x="calc(25% - 6px)" width="4" height="450" fill="url(#beam-vertical)" class="drop-shadow-glow">
      <animate attributeName="y" from="-450" to="150vh" dur="6s" begin="1s" repeatCount="indefinite"></animate>
    </rect>
  </g>

  <g class="opacity-60">
    <line x1="0" y1="75%" x2="100%" y2="75%" stroke="var(--color-surface-highest)" stroke-width="3"></line>
    <rect y="calc(75% - 6px)" width="600" height="4" fill="url(#beam-horizontal)" class="drop-shadow-glow">
      <animate attributeName="x" from="150vw" to="-600" dur="7s" begin="0.5s" repeatCount="indefinite"></animate>
    </rect>
  </g>
</svg>

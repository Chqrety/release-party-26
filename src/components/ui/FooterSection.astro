---
interface Props {
  title: string;
  links: { label: string; href: string }[];
}
const { title, links } = Astro.props;
---

<div class="flex flex-col gap-6">
  <h4 class="font-display text-primary text-xs font-bold tracking-[0.2em] uppercase">
    {title}
  </h4>

  <ul
    class="font-label text-on-surface-variant flex flex-col gap-4 text-xs tracking-widest uppercase"
  >
    {
      links.map((link) => (
        <li>
          <a href={link.href} class="hover:text-primary transition-colors duration-300">
            {link.label}
          </a>
        </li>
      ))
    }
  </ul>
</div>

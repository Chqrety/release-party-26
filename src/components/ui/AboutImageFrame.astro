---
import { cn } from "../../lib/utils"; // Import fungsi cn yang sudah kita setup

interface Props {
  src: string;
  alt: string;
  class?: string;
}

const { src, alt, class: className } = Astro.props;
---

<div
  class={cn(
    "border-2 border-surface-container/70 bg-surface-lowest p-2 lg:p-4",
    "relative flex items-center justify-center rounded-none shadow-glow",
    className
  )}
>
  <div class="absolute -top-2 -left-2 flex gap-1.5 opacity-60">
    <div class="bg-on-surface-variant h-1.5 w-1.5 rounded-full"></div>
    <div class="bg-on-surface-variant h-1.5 w-1.5 rounded-full"></div>
    <div class="bg-on-surface-variant h-1.5 w-1.5 rounded-full"></div>
  </div>
  <div class="absolute -right-2 -bottom-2 flex gap-1.5 opacity-60">
    <div class="bg-on-surface-variant h-1.5 w-1.5 rounded-full"></div>
    <div class="bg-on-surface-variant h-1.5 w-1.5 rounded-full"></div>
    <div class="bg-on-surface-variant h-1.5 w-1.5 rounded-full"></div>
  </div>

  <div class="border-surface-container/50 bg-surface-lowest h-full w-full overflow-hidden border">
    <img
      src={src}
      alt={alt}
      class="h-full w-full object-cover grayscale filter transition-transform duration-500 hover:scale-105"
    />
  </div>
</div>

---
import { cn } from "../../lib/utils";

interface Props {
  href: string;
  class?: string;
  // Tambahan opsional: target blank untuk link eksternal
  target?: "_blank" | "_self";
  rel?: string;
}

const { href, class: className, target = "_self", rel } = Astro.props;
---

<a
  href={href}
  target={target}
  rel={target === "_blank" ? "noopener noreferrer" : rel}
  class={cn(
    // 1. Base Layout & Alignment (inline-flex lebih aman dari flex)
    "inline-flex items-center justify-center gap-2 md:gap-3 rounded-none shrink-0",

    // 2. Responsive Sizing & Spacing (Mobile First)
    "px-6 py-3 md:px-8 md:py-4 lg:px-10 lg:py-5",

    // 3. Typography (Skala dari teks kecil di HP ke besar di Layar PC)
    "font-label text-sm md:text-base lg:text-lg font-bold uppercase tracking-widest",

    // 4. Colors
    "bg-primary text-[#00652e]",

    // 5. Effects, Shadows & Transitions (Brutalist Glow)
    "shadow-glow transition-all duration-300 ease-out",

    // 6. Hover State (Terangkat sedikit & Glow membesar)
    "hover:bg-primary-container hover:-translate-y-1 hover:shadow-[0_0_60px_rgba(0,253,126,0.5)]",

    // 7. Active State (Efek tombol fisik saat ditekan/diklik)
    "active:scale-95 active:translate-y-0 active:shadow-none",

    // Override styles dari props (jika ada)
    className
  )}
>
  <slot />
</a>

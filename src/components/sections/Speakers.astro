---
import { speakersData } from "../../data/content";
import SpeakerCard from "../ui/cards/SpeakerCard.astro";
---

<section id="speakers" class="bg-black py-24 md:py-32 lg:py-40">
  <div class="mx-auto max-w-7xl px-6">
    <div class="mb-16 text-center md:mb-24">
      <h2
        class="font-display text-on-surface text-4xl font-bold tracking-tighter uppercase md:text-5xl lg:text-6xl"
      >
        KENALI <span class="text-primary text-glow italic">PEMBICARA</span> KITA
      </h2>
    </div>

    <div class="flex flex-col gap-12 lg:gap-20">
      {speakersData.map((speaker) => <SpeakerCard {...speaker} />)}
    </div>
  </div>
</section>

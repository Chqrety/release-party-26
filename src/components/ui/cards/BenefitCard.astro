---
import { cn } from "../../../lib/utils";

interface Props {
  title: string;
  description: string;
  icon: any;
  colSpan?: string;
  isHighlight?: boolean;
  buttonText?: string; // Opsional: Teks tombol
  buttonHref?: string; // Opsional: Link tujuan
}

const {
  title,
  description,
  icon: Icon,
  colSpan,
  isHighlight = false,
  buttonText,
  buttonHref,
} = Astro.props;

// Dictionary Warna (Persis seperti racikan kita sebelumnya)
const styles = {
  wrapper: isHighlight
    ? "shadow-glow bg-[#A6FFB6]"
    : "bg-surface-container hover:bg-surface-high hover:border-t-primary",
  icon: isHighlight ? "text-[#004d22]" : "text-primary",
  title: isHighlight ? "text-[#004d22]" : "text-on-surface",
  desc: isHighlight ? "text-[#004d22]/80" : "text-on-surface-variant",
};
---

<div
  class={cn(
    "group flex flex-col items-start justify-between gap-8 md:gap-12 rounded-none p-6 sm:p-8 lg:p-12",
    "transition-all duration-500 border-t-4 border-transparent",
    colSpan,
    styles.wrapper
  )}
>
  <Icon
    className={cn("h-10 w-10 shrink-0 transition-colors duration-500 md:h-12 md:w-12", styles.icon)}
    strokeWidth={2}
  />

  <div class="flex w-full flex-col gap-3 md:gap-4">
    <h3
      class={cn(
        "font-display text-2xl font-bold tracking-tight uppercase lg:text-3xl transition-colors duration-500",
        styles.title
      )}
    >
      {title}
    </h3>

    <p
      class={cn(
        "font-body text-sm sm:text-base leading-relaxed lg:text-lg transition-colors duration-500",
        styles.desc
      )}
    >
      {description}
    </p>
  </div>
</div>
